{
  "name": "grubsy-backend",
  "version": "1.0.0",
  "description": "Backend API for Grubsy Platform (Node.js + Express + Prisma)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node -r dotenv/config src/server.js",
    "build": "echo \"No build step for now\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:migrate": "npm run prisma:migrate:deploy && npm run prisma:generate",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio",
    "discover:sheets": "node scripts/discover-sheets-tabs.js",
    "import:sheets": "node scripts/import-from-sheets.js",
    "import:all": "node scripts/comprehensive-import.js",
    "import:fixed": "node scripts/fixed-comprehensive-import.js",
    "import:simple": "node scripts/simple-import.js",
    "import:complete": "node scripts/complete-import.js",
    "import:final": "node scripts/final-complete-import.js",
    "import:menu": "node scripts/correct-menu-import.js",
    "import:menu-fixed": "node scripts/fixed-menu-import.js",
    "debug:sheets": "node scripts/debug-sheets-structure.js",
    "health": "node -r dotenv/config scripts/healthcheck.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit || echo \"ts not enabled yet\"",
    "start": "node -r dotenv/config src/server.js",
    "test": "jest --forceExit --detectOpenHandles --testTimeout=30000",
    "test:unit": "jest --selectProjects unit --testTimeout=30000",
    "test:integration": "jest --selectProjects integration --testTimeout=30000",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint:fix": "eslint . --ext .js,.ts --fix"
  },
  "dependencies": {
    "@playwright/test": "^1.49.1",
    "@prisma/client": "^6.14.0",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.5",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.8",
    "prisma": "^6.14.0",
    "socket.io": "^4.8.1",
    "stripe": "^17.6.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.3",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.1"
  }
}

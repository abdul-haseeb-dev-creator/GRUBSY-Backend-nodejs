{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "src/**/*",
    "routes/**/*",
    "controllers/**/*",
    "middleware/**/*",
    "services/**/*",
    "tests/**/*"
  ],
  "exclude": ["node_modules", "dist", "scripts"]
}
